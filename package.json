{
  "name": "poo-pbl-grupo-republica",
  "version": "1.0.0",
  "description": "Sistema de financas coletivas para republicas e grupos - projeto da faculdade",
  "main": "src/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "start": "npx ts-node src/index.ts",
    "dev": "npx ts-node src/presentation/server.ts"
  },
  "keywords": ["financas", "republica", "typescript", "ddd"],
  "author": "Ivanildo Marques de Souza Filho",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": [
      "src/domain/**/*.ts"
    ]
  }
}
